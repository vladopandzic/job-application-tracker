<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="app.css?v=7" />
    <link rel="stylesheet" href="marketing.css?v=4" />
    <link rel="stylesheet" href="Procoding.ApplicationTracker.Web.Root.styles.css" />
    <link rel="stylesheet" href="Procoding.ApplicationTracker.Web.styles.css" />
    <link rel="stylesheet" href="_content/Procoding.ApplicationTracker.Web.Root.styles.css" />
    <link rel="stylesheet" href="_content/Procoding.ApplicationTracker.Web.styles.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <title>JobTrek</title>
    <meta name="description" content="JobTrek helps job seekers track every application, interview and offer in one simple board." />
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />

    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script>
        // Blazor Server: backgrounding the tab on mobile drops the SignalR circuit. Instead of leaving the
        // user staring at "Attempting to reconnect… 2 of 8", reload to a fresh working page fast:
        //   - immediately if reconnection failed/was rejected (circuit gone),
        //   - immediately when the tab becomes visible again while the reconnect overlay is up,
        //   - otherwise after a short grace period if it's still trying (a quick blip that recovers is spared).
        (function () {
            var modal = null, timer = null;
            function showing() {
                return modal && (modal.classList.contains('components-reconnect-show') ||
                                 modal.classList.contains('components-reconnect-failed') ||
                                 modal.classList.contains('components-reconnect-rejected'));
            }
            function cancel() { if (timer) { clearTimeout(timer); timer = null; } }
            function evaluate() {
                if (!modal) return;
                var c = modal.classList;
                if (c.contains('components-reconnect-failed') || c.contains('components-reconnect-rejected')) {
                    location.reload();
                } else if (c.contains('components-reconnect-show')) {
                    if (!timer) { timer = setTimeout(function () { location.reload(); }, 1500); }
                } else {
                    cancel();
                }
            }
            function attach(m) {
                modal = m;
                new MutationObserver(evaluate).observe(m, { attributes: true, attributeFilter: ['class'] });
                evaluate();
            }
            document.addEventListener('visibilitychange', function () {
                if (document.visibilityState === 'visible' && showing()) { location.reload(); }
            });
            var found = document.getElementById('components-reconnect-modal');
            if (found) { attach(found); return; }
            new MutationObserver(function (muts, obs) {
                var m = document.getElementById('components-reconnect-modal');
                if (m) { attach(m); obs.disconnect(); }
            }).observe(document.documentElement, { childList: true, subtree: true });
        })();
    </script>
    @code {
        [CascadingParameter]
        private HttpContext HttpContext { get; set; } = default!;

        private IComponentRenderMode? RenderModeForPage =>  HttpContext.Request.Path == "/" ? new InteractiveServerRenderMode(true)
                                                                                            : new InteractiveServerRenderMode(false);
    }
</body>

</html>
