@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager NavigationManager
<Router AppAssembly="@typeof(AppAdapter).Assembly">

    <Found Context="routeData">

        <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">

            <NotAuthorized>
                <MudAlert Severity="Severity.Error" Class="p-5">
                    You are not authorized to visit this page
                </MudAlert>

            </NotAuthorized>
            <Authorizing>
                Logging in...
            </Authorizing>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <div style="padding:80px 32px;text-align:center;font-family:'Inter',sans-serif;">
            <h1 style="font-size:28px;font-weight:800;">Page not found</h1>
            <p style="color:#64748B;">The page you're looking for doesn't exist.</p>
            <p><a href="/" data-enhance-nav="false" style="color:#4F46E5;font-weight:600;">Go to homepage</a></p>
        </div>
    </NotFound>
</Router>
