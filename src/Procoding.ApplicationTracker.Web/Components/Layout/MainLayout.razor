@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using Procoding.ApplicationTracker.Web.Localization
@inherits LayoutComponentBase
@implements IDisposable
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager;
@inject LocalizationService Loc
@inject IJSRuntime JS

<MudThemeProvider Theme="BrandTheme.Default" />
<MudDialogProvider />
<MudSnackbarProvider />


<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" Class="mr-1" />
        <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6" Style="font-weight:700">@Branding.Name</MudText>
        <MudSpacer />
        <MudMenu Dense="true" AnchorOrigin="Origin.BottomLeft" Class="mr-1">
            <ActivatorContent>
                <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Outlined.Language" Size="Size.Small">@Loc.CurrentLanguage.ToUpperInvariant()</MudButton>
            </ActivatorContent>
            <ChildContent>
                @foreach (var lang in Loc.Languages)
                {
                    <MudMenuItem OnClick="@(() => ChangeLanguage(lang.Code))">@lang.Label</MudMenuItem>
                }
            </ChildContent>
        </MudMenu>
        <MudText Typo="Typo.body2" Class="mr-3 mud-text-secondary d-none d-sm-flex">@Name</MudText>
        <MudIconButton Href="/logout"
                       Icon="@Icons.Material.Outlined.Logout"
                       Color="Color.Inherit"
                       Title="@Loc.T("common.logout")"
                       aria-label="@Loc.T("common.logout")"
                       data-enhance-nav="false" />
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md">
        <MudPaper Width="250px" Class="py-3" Elevation="0">
            <MudNavMenu>
                <div class="d-none d-md-flex align-center px-4 pb-1">
                    <MudIcon Icon="@Icons.Material.Filled.Timeline" Color="Color.Primary" Class="mr-2" />
                    <MudText Typo="Typo.h6" Style="font-weight:700">@Branding.Name</MudText>
                </div>
                <MudText Typo="Typo.body2" Class="px-4 mud-text-secondary">@(IsAdminView ? Loc.T("layout.adminView") : Loc.T("layout.candidateView"))</MudText>
                <MudDivider Class="my-2" />
                <MudNavLink Match="NavLinkMatch.All" Href="/home" Icon="@Icons.Material.Outlined.Home">@Loc.T("nav.home")</MudNavLink>
                <AuthorizeView Roles="Candidate">
                    <MudNavLink Match="NavLinkMatch.All" Href="/my-job-applications/board" Icon="@Icons.Material.Outlined.ViewKanban">@Loc.T("nav.board")</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.All" Href="/my-job-applications" Icon="@Icons.Material.Outlined.List">@Loc.T("nav.myApplications")</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.All" Href="/my-job-applications/new" Icon="@Icons.Material.Outlined.Add">@Loc.T("nav.newApplication")</MudNavLink>
                </AuthorizeView>
                <AuthorizeView Roles="Employee">
                    <MudNavLink Match="NavLinkMatch.All" Href="/job-applications" Icon="@Icons.Material.Outlined.WorkOutline">@Loc.T("nav.jobApplications")</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.All" Href="/candidates" Icon="@Icons.Material.Outlined.People">@Loc.T("nav.candidates")</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.All" Href="/companies" Icon="@Icons.Material.Outlined.Business">@Loc.T("nav.companies")</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.All" Href="/job-application-sources" Icon="@Icons.Material.Outlined.Link">@Loc.T("nav.sources")</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.All" Href="/employees" Icon="@Icons.Material.Outlined.Badge">@Loc.T("nav.employees")</MudNavLink>
                    <MudNavLink Match="NavLinkMatch.All" Href="/translations" Icon="@Icons.Material.Outlined.Translate">@Loc.T("nav.translations")</MudNavLink>

                </AuthorizeView>

            </MudNavMenu>
        </MudPaper>
    </MudDrawer>
    @* Keep MudMainContent's built-in top offset (= app bar height) — do NOT set pt/py on it or the
       content slides under the fixed app bar. Add breathing room via the inner wrapper instead. *@
    <MudMainContent Class="pl-5 pr-5 pb-8">
        <div class="pt-4">
            @Body
        </div>
    </MudMainContent>
</MudLayout>


<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
@code {

    public string? Name { get; set; }

    public bool IsAdminView { get; set; }

    private bool _drawerOpen = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    protected async override Task OnInitializedAsync()
    {
        var authstate = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authstate.User;
        IsAdminView = user.IsInRole("Employee");
        Name = user.Identity?.Name;

        await Loc.EnsureLoadedAsync();
        Loc.OnChange += OnLocalizationChanged;
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    // On mobile the drawer is a temporary overlay; close it after navigating to a new page
    // so the user isn't left staring at the scrim. On desktop (>= Md) it stays put.
    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (!_drawerOpen)
        {
            return;
        }

        var width = await JS.InvokeAsync<int>("eval", "window.innerWidth");
        if (width < 960)
        {
            _drawerOpen = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Loc.LoadLanguageFromStorageAsync();
        }
    }

    private void OnLocalizationChanged() => InvokeAsync(StateHasChanged);

    private async Task ChangeLanguage(string code) => await Loc.SetLanguageAsync(code);

    public void Dispose()
    {
        Loc.OnChange -= OnLocalizationChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
