@model Procoding.ApplicationTracker.DTOs.Request.Employees.EmployeeLoginRequestDTO;
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject Procoding.ApplicationTracker.Web.Localization.ServerSideTranslations Tr
@{
    Layout = null;
    var lang = Context.Request.Cookies["jf-lang"] == "en" ? "en" : "hr";
    await Tr.EnsureLoadedAsync();
    ViewBag.Title = Tr.T("auth.admin.title", lang);

    // Prefill demo admin credentials in the dev environment only.
    var devEmail = Env.IsDevelopment() ? "admin@jobflow.app" : "";
    var devPassword = Env.IsDevelopment() ? "Admin123!" : "";
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Tr.T("auth.admin.title", lang) · JobTrek</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/auth.css?v=2" />
</head>
<body>
    <div class="auth-wrap">
        <aside class="auth-brand">
            <a class="auth-logo" href="/"><span class="auth-logo-mark"></span> JobTrek</a>
            <div class="auth-brand-copy">
                <h1>@Tr.T("auth.admin.console", lang)</h1>
                <p>@Tr.T("auth.admin.consoleSub", lang)</p>
                <ul class="auth-points">
                    <li>@Tr.T("auth.admin.point1", lang)</li>
                    <li>@Tr.T("auth.admin.point2", lang)</li>
                    <li>@Tr.T("auth.admin.point3", lang)</li>
                </ul>
            </div>
            <div class="auth-brand-foot">© 2026 JobTrek</div>
        </aside>

        <main class="auth-panel">
            <div class="auth-card">
                <a class="auth-mobile-brand" href="/"><span class="auth-logo-mark"></span> JobTrek</a>
                <h2>@Tr.T("auth.admin.title", lang)</h2>
                <p class="auth-sub">@Tr.T("auth.admin.forStaff", lang)</p>

                @if (ViewBag.Message != null)
                {
                    <div class="auth-error">@ViewBag.Message</div>
                }

                @using (Html.BeginForm("Login", "Admin", FormMethod.Post, new { @class = "auth-form" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "auth-error" })

                    <label for="Email">@Tr.T("auth.field.email", lang)</label>
                    <input class="auth-input" type="email" name="Email" id="Email" value="@devEmail" placeholder="you@company.com" autofocus />
                    @Html.ValidationMessageFor(a => a.Email, "", new { @class = "auth-error" })

                    <label for="Password">@Tr.T("auth.field.password", lang)</label>
                    <input class="auth-input" type="password" name="Password" id="Password" value="@devPassword" placeholder="••••••••" />
                    @Html.ValidationMessageFor(a => a.Password, "", new { @class = "auth-error" })

                    <button type="submit" class="auth-btn">@Tr.T("auth.admin.submit", lang)</button>
                }

                <p class="auth-alt">@Tr.T("auth.admin.notAdmin", lang) <a href="/Login">@Tr.T("auth.admin.candidateSignin", lang)</a></p>
            </div>
        </main>
    </div>
</body>
</html>
