@model Procoding.ApplicationTracker.DTOs.Request.Employees.EmployeeLoginRequestDTO;
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@{
    Layout = null;
    var hr = Context.Request.Cookies["jf-lang"] != "en";
    ViewBag.Title = hr ? "Prijava za administratore" : "Admin sign in";

    // Prefill demo admin credentials in the dev environment only.
    var devEmail = Env.IsDevelopment() ? "admin@jobflow.app" : "";
    var devPassword = Env.IsDevelopment() ? "Admin123!" : "";
}
<!DOCTYPE html>
<html lang="@(hr ? "hr" : "en")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(hr ? "Prijava za administratore" : "Admin sign in") · JobTrek</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/auth.css?v=2" />
</head>
<body>
    <div class="auth-wrap">
        <aside class="auth-brand">
            <a class="auth-logo" href="/"><span class="auth-logo-mark"></span> JobTrek</a>
            <div class="auth-brand-copy">
                <h1>@(hr ? "Administratorska konzola." : "Admin console.")</h1>
                <p>@(hr ? "Upravljaj kandidatima, tvrtkama, izvorima i prijevodima aplikacije." : "Manage candidates, companies, sources and the app's translations.")</p>
                <ul class="auth-points">
                    <li>@(hr ? "Potpun pregled svih prijava" : "Full view across all applications")</li>
                    <li>@(hr ? "Uređuj hrvatski i engleski tekst sučelja" : "Edit the Croatian & English UI text")</li>
                    <li>@(hr ? "Održavaj podatke platforme urednima" : "Keep the platform data tidy")</li>
                </ul>
            </div>
            <div class="auth-brand-foot">© 2026 JobTrek</div>
        </aside>

        <main class="auth-panel">
            <div class="auth-card">
                <a class="auth-mobile-brand" href="/"><span class="auth-logo-mark"></span> JobTrek</a>
                <h2>@(hr ? "Prijava za administratore" : "Admin sign in")</h2>
                <p class="auth-sub">@(hr ? "Za interno osoblje i administratore." : "For internal staff and administrators.")</p>

                @if (ViewBag.Message != null)
                {
                    <div class="auth-error">@ViewBag.Message</div>
                }

                @using (Html.BeginForm("Login", "Admin", FormMethod.Post, new { @class = "auth-form" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "auth-error" })

                    <label for="Email">Email</label>
                    <input class="auth-input" type="email" name="Email" id="Email" value="@devEmail" placeholder="you@company.com" autofocus />
                    @Html.ValidationMessageFor(a => a.Email, "", new { @class = "auth-error" })

                    <label for="Password">@(hr ? "Lozinka" : "Password")</label>
                    <input class="auth-input" type="password" name="Password" id="Password" value="@devPassword" placeholder="••••••••" />
                    @Html.ValidationMessageFor(a => a.Password, "", new { @class = "auth-error" })

                    <button type="submit" class="auth-btn">@(hr ? "Prijavi se kao administrator" : "Sign in as admin")</button>
                }

                <p class="auth-alt">@(hr ? "Nisi administrator?" : "Not an admin?") <a href="/Login">@(hr ? "Prijava za kandidate" : "Candidate sign in")</a></p>
            </div>
        </main>
    </div>
</body>
</html>
