@model Procoding.ApplicationTracker.DTOs.Request.Candidates.CandidateLoginRequestDTO;
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
@inject Procoding.ApplicationTracker.Web.Localization.ServerSideTranslations Tr
@{
    Layout = null;

    // Match the language the user picked in the app (mirrored into the jf-lang cookie). Default Croatian.
    var lang = Context.Request.Cookies["jf-lang"] == "en" ? "en" : "hr";
    await Tr.EnsureLoadedAsync();
    ViewBag.Title = Tr.T("auth.login.title", lang);

    // Prefill demo credentials in the test/dev environment only.
    var devEmail = Env.IsDevelopment() ? "demo@jobflow.app" : "";
    var devPassword = Env.IsDevelopment() ? "Demo123!" : "";
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Tr.T("auth.login.title", lang) · JobTrek</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/auth.css?v=2" />
</head>
<body>
    <div class="auth-wrap">
        <aside class="auth-brand">
            <a class="auth-logo" href="/"><span class="auth-logo-mark"></span> JobTrek</a>
            <div class="auth-brand-copy">
                <h1>@Tr.T("auth.login.welcomeBack", lang)</h1>
                <p>@Tr.T("auth.login.welcomeSub", lang)</p>
                <ul class="auth-points">
                    <li>@Tr.T("auth.point.pipeline", lang)</li>
                    <li>@Tr.T("auth.point.neverLose", lang)</li>
                    <li>@Tr.T("auth.point.whatsNext", lang)</li>
                </ul>
            </div>
            <div class="auth-brand-foot">© 2026 JobTrek</div>
        </aside>

        <main class="auth-panel">
            <div class="auth-card">
                <a class="auth-mobile-brand" href="/"><span class="auth-logo-mark"></span> JobTrek</a>
                <h2>@Tr.T("auth.login.title", lang)</h2>
                <p class="auth-sub">@Tr.T("auth.login.enterDetails", lang)</p>

                @if (Context.Request.Query["registered"] == "1")
                {
                    <div class="auth-note">@Tr.T("auth.login.accountCreated", lang)</div>
                }
                @if (Context.Request.Query["confirmEmail"] == "1")
                {
                    <div class="auth-note">@(lang == "en"
                        ? "Almost there! Check your email (inbox and spam) and click the confirmation link before signing in."
                        : "Još samo korak! Provjeri email (inbox i spam) i klikni potvrdni link prije prijave.")</div>
                }
                @if (Context.Request.Query["confirmed"] == "1")
                {
                    <div class="auth-note">@(lang == "en"
                        ? "Email confirmed — you can sign in now. ✅"
                        : "Email potvrđen — sada se možeš prijaviti. ✅")</div>
                }
                @if (Context.Request.Query["confirmError"] == "1")
                {
                    <div class="auth-error">@(lang == "en"
                        ? "Confirmation link is invalid or has expired. Try signing in to request a new one."
                        : "Potvrdni link nije važeći ili je istekao.")</div>
                }

                @using (Html.BeginForm("Login", "Login", FormMethod.Post, new { @class = "auth-form" }))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "auth-error" })

                    <label for="Email">@Tr.T("auth.field.email", lang)</label>
                    <input class="auth-input" type="email" name="Email" id="Email" value="@devEmail" placeholder="you@example.com" autofocus />
                    @Html.ValidationMessageFor(a => a.Email, "", new { @class = "auth-error" })

                    <label for="Password">@Tr.T("auth.field.password", lang)</label>
                    <input class="auth-input" type="password" name="Password" id="Password" value="@devPassword" placeholder="••••••••" />
                    @Html.ValidationMessageFor(a => a.Password, "", new { @class = "auth-error" })

                    <button type="submit" class="auth-btn">@Tr.T("auth.login.submit", lang)</button>
                }

                <p class="auth-alt">@Tr.T("auth.login.noAccount", lang) <a href="/Signup">@Tr.T("auth.login.createFree", lang)</a></p>
                <p class="auth-alt">@Tr.T("auth.login.staff", lang) <a href="/admin/login">@Tr.T("auth.login.adminSignin", lang)</a></p>
            </div>
        </main>
    </div>
</body>
</html>
