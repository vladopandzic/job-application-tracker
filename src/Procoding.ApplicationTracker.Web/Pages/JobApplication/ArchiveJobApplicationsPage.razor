@page "/my-job-applications/archive"
@using MudBlazor
@using Procoding.ApplicationTracker.DTOs.Model

<MudStack Row AlignItems="AlignItems.Center" Class="mb-4 mt-2">
    <MudIcon Icon="@Icons.Material.Outlined.Archive" Color="Color.Primary" Class="mr-2" />
    <MudText Typo="Typo.h5" Style="font-weight:600">Arhiva</MudText>
    <MudSpacer />
    <MudButton Href="my-job-applications" StartIcon="@Icons.Material.Outlined.List" Variant="Variant.Outlined" Color="Color.Primary">Prijave</MudButton>
</MudStack>

@if (ViewModel.IsLoading && !ViewModel.JobApplications.Any())
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (!ViewModel.JobApplications.Any())
{
    <MudPaper Class="pa-8 mt-2" Style="text-align:center;">
        <MudIcon Icon="@Icons.Material.Outlined.Inventory2" Size="Size.Large" Class="mud-text-secondary mb-2" />
        <MudText Typo="Typo.h6" Class="mb-1">Nema arhiviranih prijava</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Kad arhiviraš prijavu, pojavit će se ovdje — možeš je vratiti ili trajno izbrisati.</MudText>
    </MudPaper>
}
else
{
    @foreach (var app in ViewModel.JobApplications)
    {
        <MudPaper Class="pa-3 mb-3" Elevation="2">
            <div class="d-flex align-center" style="gap:12px;flex-wrap:wrap;">
                <div style="flex:1;min-width:180px;">
                    <MudText Typo="Typo.body1" Style="font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@app.JobPositionTitle</MudText>
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">@app.Company?.CompanyName@(string.IsNullOrWhiteSpace(app.ApplicationSource?.Name) ? "" : $" · {app.ApplicationSource!.Name}")</MudText>
                </div>
                <div class="d-flex" style="gap:6px;">
                    <MudButton OnClick="@(() => Restore(app.Id))" Disabled="ViewModel.IsSaving" StartIcon="@Icons.Material.Outlined.Unarchive" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary">Vrati</MudButton>
                    <MudButton OnClick="@(() => Delete(app))" Disabled="ViewModel.IsSaving" StartIcon="@Icons.Material.Outlined.DeleteForever" Size="Size.Small" Variant="Variant.Text" Color="Color.Error">Izbriši</MudButton>
                </div>
            </div>
        </MudPaper>
    }
}
